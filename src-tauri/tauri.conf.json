{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Focus",
  "version": "1.1.0",
  "identifier": "com.aowshad.focus",
  "build": {
    "beforeDevCommand": "rm -rf dist && mkdir -p dist && cp index.html dist/ && cp -R css js dist/",
    "beforeBuildCommand": "rm -rf dist && mkdir -p dist && cp index.html dist/ && cp -R css js dist/",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Focus",
        "width": 1180,
        "height": 800,
        "minWidth": 400,
        "minHeight": 640,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Productivity",
    "copyright": "© 2026 Aowshad Himel",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
